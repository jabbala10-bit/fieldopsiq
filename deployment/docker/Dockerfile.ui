# FieldOpsIQ — Gradio UI image.
# Lightweight separate image since the UI has no STT/LLM dependencies of its
# own; it only talks to the FastAPI service over HTTP.

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir gradio==4.44.1 httpx==0.27.2

COPY src/ui/ ./src/ui/
COPY src/__init__.py ./src/__init__.py

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    FIELDOPSIQ_API_URL=http://api:8000

EXPOSE 7860

CMD ["python", "src/ui/app.py"]
